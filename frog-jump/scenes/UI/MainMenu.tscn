[sub_resource type="Shader" id="Shader_n327r"]
code = "shader_type canvas_item;

uniform sampler2D SCREEN_TEXTURE : hint_screen_texture, filter_linear_mipmap;

uniform float distortion_strength = 0.003;
uniform float chromatic_amount = 0.002;
uniform float scanline_strength = 0.15;
uniform float vignette_strength = 0.6;
uniform float glow_strength = 0.15;
uniform float glitch_amount = 0.0;

void fragment()
{
    vec2 uv = SCREEN_UV;

    // Distortion wave
    float wave = sin(uv.y * 40.0 + TIME * 3.0) * distortion_strength;
    uv.x += wave;

    // Glitch effect
    float glitch = step(0.98, sin(TIME * 6.0 + uv.y * 25.0));
    uv.x += glitch * glitch_amount;

    // Chromatic aberration (fixed sampling)
    float r = texture(SCREEN_TEXTURE, uv + vec2(chromatic_amount,0)).r;
    float g = texture(SCREEN_TEXTURE, uv).g;
    float b = texture(SCREEN_TEXTURE, uv - vec2(chromatic_amount,0)).b;

    vec3 color = vec3(r,g,b);

    // Scanlines
    float scan = sin(uv.y * 800.0) * scanline_strength;
    color -= scan;

    // Glow pulse
    float pulse = sin(TIME * 2.0) * 0.5 + 0.5;
    color += color * glow_strength * pulse;

    // Vignette
    float dist = distance(uv, vec2(0.5));
    float vignette = smoothstep(0.8, vignette_strength * 0.799, dist);
    color *= vignette;

    // Slight color grading
    color.r *= 1.05;
    color.b *= 1.08;

    COLOR = vec4(color,1.0);
}"

